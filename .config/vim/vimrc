set termwinsize=10x200

highlight TabLineFill ctermfg=LightGreen ctermbg=DarkGreen
highlight TabLine ctermfg=Blue ctermbg=Yellow
highlight TabLineSel ctermfg=Red ctermbg=Yellow

let g:dark_theme = 'ayu'
let g:light_theme = 'github'
let g:current_theme = g:dark_theme

" more contrast
let g:afterglow_blackout=1

let g:afterglow_italic_comments=1

let g:afterglow_inherit_background=1

" Function to toggle between light and dark themes
function! ToggleTheme()
    if g:current_theme == g:dark_theme
        let g:current_theme = g:light_theme
        let g:airline_theme = "github"
        set background=light
    else
        let g:current_theme = g:dark_theme
        let g:airline_theme = "ayu"
        highlight Cursor guifg=yellow guibg=darkgreen
        "set background=dark
    endif
    execute 'colorscheme' g:current_theme
endfunction

nnoremap <F12> :call ToggleTheme()<CR>

" Map the toggle function to a keybinding


let mapleader =" "

            
" set bigger history of executed commands 
set history=1000

" show current mode at the bottom 
set showmode

" show partial typed commands in status line  
set showcmd

set showmatch
set matchtime=3

