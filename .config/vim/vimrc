nnoremap <leader>x :stop<CR>:execute 'silent! !bash ~/.local/bin/vim_to_tmux.sh'<CR>

function! StartTmux()
    execute '!tmux attach-session -t your_session_name || tmux new-session -s your_session_name'
endfunction

command! Tmux call StartTmux()

" New lines inherit the indentation of previous lines 
:set autoindent       " Copies the indent from the previous line
:set smartindent      " Adds extra indentation in some cases
:set shiftwidth=4     " Sets the number of spaces for each indent level
" Set tab width to 2 columns.
:set tabstop=4        " Sets the number of spaces for a tab
"on pressing tab, insert 4 spaces
:set expandtab        " Converts tabs to spaces

filetype plugin indent on

" Turn syntax highlighting on.
syntax on
set clipboard=unnamedplus

" autoindent for files
set ai
set si
set pastetoggle=<f5>


" disable vim help menu 
:nmap <F1> :echo<CR>
:imap <F1> <C-o>:echo<CR>

